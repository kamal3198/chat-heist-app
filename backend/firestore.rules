rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isParticipant(participants) {
      return isSignedIn() && request.auth.uid in participants;
    }

    function canAccessChat(chatId) {
      return isParticipant(get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
    }

    function canWriteChat(chatId) {
      return isSignedIn() &&
        request.auth.uid in getAfter(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function retentionEnabled(chatId) {
      return get(/databases/$(database)/documents/chats/$(chatId)).data.retentionPolicy.enabled == true;
    }

    function sameParticipants(before, after) {
      return before.size() == after.size() &&
        before.hasAll(after) &&
        after.hasAll(before);
    }

    function immutableUsernameFields() {
      return request.resource.data.username_search == resource.data.username_search &&
             request.resource.data.usernameLower == resource.data.usernameLower &&
             request.resource.data.username == resource.data.username &&
             request.resource.data.lastUsernameChangeAt == resource.data.lastUsernameChangeAt &&
             request.resource.data.usernameChangeTimestamps == resource.data.usernameChangeTimestamps;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSelf(userId);
      allow update: if isSelf(userId) && immutableUsernameFields();
      allow delete: if false;
    }

    match /chats/{chatId} {
      allow get, list: if isParticipant(resource.data.participants);
      allow create: if isSignedIn() &&
        request.resource.data.participants is list &&
        request.resource.data.participants.size() == 2 &&
        isParticipant(request.resource.data.participants);
      allow update: if isParticipant(resource.data.participants) &&
        sameParticipants(resource.data.participants, request.resource.data.participants);
      allow delete: if false;

      match /messages/{messageId} {
        allow get, list: if canAccessChat(chatId);
        allow create: if canWriteChat(chatId) &&
          request.auth.uid == request.resource.data.senderId &&
          request.resource.data.receiverId in
            getAfter(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          request.resource.data.deliveryStatus == 'sent';
        allow update: if canWriteChat(chatId) && (
          // Receiver can only move delivery state from sent -> seen.
          (
            request.auth.uid == resource.data.receiverId &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'deliveryStatus', 'seenAt'
            ]) &&
            resource.data.deliveryStatus == 'sent' &&
            request.resource.data.deliveryStatus == 'seen'
          ) ||
          // Participant can soft-delete only for self when retention is disabled
          (
            !retentionEnabled(chatId) &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['deletedFor']) &&
            request.resource.data.deletedFor.hasAll(resource.data.deletedFor) &&
            request.resource.data.deletedFor.size() <= resource.data.deletedFor.size() + 1 &&
            request.auth.uid in request.resource.data.deletedFor &&
            (
              request.resource.data.deletedFor.size() == resource.data.deletedFor.size() ||
              !(request.auth.uid in resource.data.deletedFor)
            )
          )
        );
        allow delete: if false;
      }
    }

    function validUserPublicSearchQuery() {
      return request.query.limit != null &&
             request.query.limit <= 20;
    }

    match /users_public/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && validUserPublicSearchQuery();
      allow write: if false;
    }

    match /usernames/{username} {
      allow read, write: if false;
    }

    match /reserved_usernames/{username} {
      allow read, write: if false;
    }

    match /contact_requests/{requestId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.sender ||
        request.auth.uid == resource.data.receiver
      );
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.sender;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.sender ||
        request.auth.uid == resource.data.receiver
      );
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.sender ||
        request.auth.uid == resource.data.receiver
      );
    }

    match /blocked_users/{blockId} {
      allow read, write: if isSignedIn() && request.auth.uid == request.resource.data.blocker;
      allow get, delete: if isSignedIn() && request.auth.uid == resource.data.blocker;
    }

    match /messages/{messageId} {
      allow read, write: if false;
    }

    match /groups/{groupId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.createdBy;
      allow update, delete: if isSignedIn() && request.auth.uid in resource.data.admins;
    }

    match /channels/{channelId} {
      allow read: if isSignedIn() && (
        !resource.data.isPrivate || request.auth.uid in resource.data.subscribers
      );
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.creator;
      allow update, delete: if isSignedIn() && request.auth.uid in resource.data.admins;
    }

    match /statuses/{statusId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.user;
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.user;
    }

    match /ai_settings/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /device_sessions/{sessionId} {
      allow read, write: if isSignedIn() && request.auth.uid == resource.data.user;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.user;
    }

    match /call_logs/{callId} {
      allow read, write: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.caller;
    }
  }
}
